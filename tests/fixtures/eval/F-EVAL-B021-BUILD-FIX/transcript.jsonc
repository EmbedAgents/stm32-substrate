        "old_string": "/* Private functions ---------------------------------------------------------*/\n\n/**\n  * @brief  Main program",
        "new_string": "/* Private functions ---------------------------------------------------------*/\n\n/* --- RES-032 TEMPORARY VCP banner instrumentation \u2014 REMOVE AFTER VERIFY --- */\nstatic void vcp_banner_init(void)\n{\n  RCC->AHB2ENR  |= RCC_AHB2ENR_GPIOAEN;\n  RCC->APB1ENR1 |= RCC_APB1ENR1_USART2EN;\n  /* PA2 = USART2_TX, AF7 */\n  GPIOA->MODER  = (GPIOA->MODER & ~(3U << (2U * 2U))) | (2U << (2U * 2U));\n  GPIOA->AFR[0] = (GPIOA->AFR[0] & ~(0xFU << (4U * 2U))) | (7U << (4U * 2U));\n  USART2->BRR = 80000000U / 115200U; /* PCLK1 = 80 MHz */\n  USART2->CR1 = USART_CR1_TE | USART_CR1_UE;\n}\n\nstatic void vcp_banner_puts(const char *s)\n{\n  for (; *s != '\\0'; s++)\n  {\n    while ((USART2->ISR & USART_ISR_TXE) == 0U) {}\n    USART2->TDR = (uint8_t)*s;\n  }\n  while ((USART2->ISR & USART_ISR_TC) == 0U) {}\n}\n/* --- end temporary instrumentation --- */\n\n/**\n  * @brief  Main program"
      }
