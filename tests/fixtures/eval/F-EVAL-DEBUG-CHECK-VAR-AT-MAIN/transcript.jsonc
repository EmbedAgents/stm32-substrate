      "args": {
        "command": "arm-none-eabi-nm Projects/NUCLEO-L476RG/Examples/PWR/VCP-ECHO/STM32CubeIDE/Debug/VCP-ECHO.elf 2>/dev/null | grep -i uart_buf_count; arm-none-eabi-nm Projects/NUCLEO-L476RG/Examples/GPIO/BLINKY/STM32CubeIDE/Debug/BLINKY.elf 2>/dev/null | grep -i uart_buf_count",
        "description": "Find which ELF defines uart_buf_count"
      }
    },
    {
      "name": "Bash",
      "args": {
        "command": "which arm-none-eabi-nm arm-none-eabi-gdb; for e in Projects/NUCLEO-L476RG/Examples/PWR/VCP-ECHO/STM32CubeIDE/Debug/VCP-ECHO.elf Projects/NUCLEO-L476RG/Examples/GPIO/BLINKY/STM32CubeIDE/Debug/BLINKY.elf; do echo \"== $e\"; \"$(find /opt /usr -name 'arm-none-eabi-nm' -type f 2>/dev/null | head -1)\" \"$e\" | grep -iE 'uart_buf_count| main$'; done",
        "description": "Locate nm and grep ELFs for uart_buf_count and main"
      }
    },
    {
      "name": "Bash",
      "args": {
        "command": "NM=/opt/st/stm32cubeclt_1.21.0/GNU-tools-for-STM32/bin/arm-none-eabi-nm; for e in Projects/NUCLEO-L476RG/Examples/PWR/VCP-ECHO/STM32CubeIDE/Debug/VCP-ECHO.elf Projects/NUCLEO-L476RG/Examples/PWR/FAULTING/STM32CubeIDE/Debug/FAULTING.elf Projects/NUCLEO-L476RG/Examples/GPIO/BLINKY/STM32CubeIDE/Debug/BLINKY.elf; do echo \"== $(basename $e)\"; $NM \"$e\" | grep -i 'buf\\|uart' | head -8; done",
        "description": "Search ELFs for uart/buf symbols"
      }
    },
    {
      "name": "Bash",
      "args": {
        "command": "NM=/opt/st/stm32cubeclt_1.21.0/GNU-tools-for-STM32/bin/arm-none-eabi-nm; for e in Projects/NUCLEO-L476RG/Examples/PWR/VCP-ECHO/STM32CubeIDE/Debug/VCP-ECHO.elf Projects/NUCLEO-L476RG/Examples/PWR/FAULTING/STM32CubeIDE/Debug/FAULTING.elf; do echo \"== $(basename $e)\"; $NM \"$e\" | grep -i 'count'; done; grep -rn \"uart_buf_count\" Projects/NUCLEO-L476RG/Examples --include=*.c --include=*.h -l | head",
        "description": "Search for uart_buf_count in symbols and sources"
      }
    },
    {
      "name": "Bash",
      "args": {
        "command": "STM32_PROGRAMMER_DEFAULT_SN=066DFF485754727567021514 stm32 debug callstack Projects/NUCLEO-L476RG/Examples/PWR/VCP-ECHO/STM32CubeIDE/Debug/VCP-ECHO.elf",
        "description": "Resolve callstack against VCP-ECHO ELF symbols"
