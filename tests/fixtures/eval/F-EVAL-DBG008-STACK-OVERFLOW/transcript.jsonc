    {
      "name": "Bash",
      "args": {
        "command": "# Check the FAULTING map \u2014 most likely candidate given PC=0x08013074\npython3 -c \"\nimport re\nmf = '/home/user/claude-projects/stm32-substrate/tests/fixtures/projects/F-PROJ-NUCLEO-L476RG/Projects/NUCLEO-L476RG/Examples/PWR/FAULTING/STM32CubeIDE/Debug/FAULTING.map'\ntxt = open(mf).read()\n\n# Find code section covering 0x08013074\npc = 0x08013074\nprint('=== Sections covering PC 0x{:08X} ==='.format(pc))\nfor m in re.finditer(r'0x([0-9a-f]{8,})\\s+0x([0-9a-f]+)\\s+(\\S+)', txt):\n    base = int(m.group(1), 16)\n    size = int(m.group(2), 16)\n    if base <= pc < base + size:\n        print(f'  base=0x{base:08X}  size=0x{size:X}  {m.group(3)}')\n\n# Print RAM layout summary: _estack, _end, __bss_end__, heap\nprint()\nprint('=== RAM layout symbols ===')\nfor sym in ['_estack', '_end', '__bss_end__', '__end__', '_Min_Stack', '_Min_Heap', 'PROVIDE']:\n    for m in re.finditer(r'(0x[0-9a-f]+)\\s+' + re.escape(sym) if sym not in ('PROVIDE',) else sym + r'.*', txt):\n        print(f'  {sym}: {m.group(0)[:80]}')\n        break\n\"\n",
