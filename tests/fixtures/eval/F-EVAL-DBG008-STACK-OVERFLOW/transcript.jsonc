        "command": "python3 -c \"\nimport json\nwith open('/home/user/.claude/projects/-home-user-claude-projects-stm32-substrate-tests-fixtures-projects-STM32CubeL4-Projects-NUCLEO-L476RG-Examples-GPIO-GPIO-IOToggle-STM32CubeIDE/68e91a00-93db-43f4-9665-7b0d117d27b2/tool-results/bqho9f20q.txt') as f:\n    data = json.load(f)\n\n# Print just the fault-relevant registers\nfor reg in ['CFSR', 'HFSR', 'DFSR', 'MMFAR', 'BFAR', 'SHCSR']:\n    if reg in data['registers']:\n        r = data['registers'][reg]\n        print(f'=== {reg} @ 0x{int(r[\\\"address\\\"],16) if isinstance(r[\\\"address\\\"],str) else r[\\\"address\\\"]:08X}  raw=0x{r[\\\"raw_value\\\"]:08X} ===')\n        for fname, fv in r['fields'].items():\n            if fv['raw_value'] != 0:\n                print(f'  *** {fname} = {fv[\\\"raw_value\\\"]}  ({fv.get(\\\"enum_name\\\",\\\"\\\")}) [bit {fv[\\\"bit_offset\\\"]}]')\n            else:\n                print(f'      {fname} = 0')\n        print()\n\"\n",
