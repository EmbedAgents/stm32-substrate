        "command": "python3 -c \"\nimport json\ns=json.load(open('/home/anup/claude-projects/stm32-substrate/src/embedagents/stm32/schemas/stm32-runtime-defaults.schema.json'))\nprint(json.dumps(s.get('properties',{}).get('vcp'), indent=1))\n\"; ls /home/anup/claude-projects/stm32-substrate/.claude/ 2>/dev/null; ls /home/anup/claude-projects/stm32-substrate/tests/fixtures/projects/F-PROJ-NUCLEO-L476RG/.claude 2>/dev/null",
