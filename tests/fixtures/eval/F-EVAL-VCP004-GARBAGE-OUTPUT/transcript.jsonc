    {
      "name": "Bash",
      "args": {
        "command": "stm32 prog reset --help 2>&1; echo \"---\"; stm32 debug --help 2>&1",
        "description": "Check available reset and debug subcommand options"
      }
    },
    {
      "name": "Bash",
      "args": {
        "command": "stm32 prog reset && sleep 0.5 && stm32 debug read-peripheral USART2",
        "description": "Reset target, let it run 500ms past UART init, then halt and read USART2 state"
      }
    },
    {
      "name": "Bash",
      "args": {
        "command": "stm32 debug decode-hardfault",
        "description": "Decode CPU fault registers to see if firmware is crashing"
      }
    },
