    {
      "name": "Bash",
      "args": {
        "command": "pwd && ls *.jsonc 2>/dev/null; grep -rn --include=\"*.jsonc\" -l \"firmware\" . .claude 2>/dev/null | head; grep -rn \"baud\" .claude/*.jsonc stm32-project*.jsonc 2>/dev/null | head",
