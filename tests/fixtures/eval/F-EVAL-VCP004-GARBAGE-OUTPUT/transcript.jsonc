        "command": "STM32_PROGRAMMER_DEFAULT_SN=066DFF485754727567021514 stm32 debug read-peripheral RCC 2>&1 | python3 -c \"\nimport json,sys\nd=json.load(sys.stdin)\nfor r in ('CR','CFGR','PLLCFGR','CCIPR'):\n    reg=d['registers'][r]\n    nz={k:v['raw_value'] for k,v in reg['fields'].items() if v['raw_value']}\n    print(r, hex(reg['raw_value']), nz)\n\"",
