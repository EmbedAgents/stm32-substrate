    {
      "name": "Bash",
      "args": {
        "command": "STM32_PROGRAMMER_DEFAULT_SN=066DFF485754727567021514 python - <<'PY'\nfrom embedagents.stm32.context import SubstrateContext\nfrom embedagents.stm32.debug import Debug\nctx = SubstrateContext.from_environment()\nwith Debug(ctx).start_session(elf_path=\"Projects/NUCLEO-L476RG/Examples/GPIO/BLINKY/STM32CubeIDE/Debug/BLINKY.elf\") as s:\n    s.reset(halt_after=True)\n    bp = s.set_breakpoint(\"SystemClock_Config\")\n    print(\"BP addr:\", bp.address, \"line:\", bp.line)\n    res = s.run_until_breakpoint(timeout_s=20)\n    print(\"RUN:\", res)\n    if res.breakpoint_hit:\n        regs = s.read_registers()\n        d = regs.registers if hasattr(regs, \"registers\") else regs\n        print(\"r0 =\", d.get(\"r0\") if hasattr(d, \"get\") else d)\n        print(\"pc =\", d.get(\"pc\") if hasattr(d, \"get\") else \"\")\nPY",
        "description": "Reset, break at SystemClock_Config, read r0"
      }
