      "args": {
        "command": "python3 -c \"\nimport json\nd=json.load(open('/home/anup/.claude/projects/-home-anup-claude-projects-stm32-substrate-tests-fixtures-projects-F-PROJ-NUCLEO-L476RG/069d20c1-63b6-4979-b44a-2a426e5fe9f3/tool-results/bf7v9fd8n.txt'))\nregs=d['peripheral_dumps'][0]['registers']\nfor name in ('CFSR_UFSR_BFSR_MMFSR','CFSR','HFSR','MMFAR','BFAR','AFSR','SHCSR','ICSR'):\n    r=regs.get(name)\n    if not r: continue\n    print(name, hex(r['raw_value']))\n    for f,fd in r.get('fields',{}).items():\n        if fd['raw_value']: print('  ',f,'=',fd['raw_value'])\n\"",
