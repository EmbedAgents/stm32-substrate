        "command": "python3 -c \"\nimport json\nd=json.load(open('/home/anup/.claude/projects/-home-anup-claude-projects-stm32-substrate-tests-fixtures-projects-F-PROJ-NUCLEO-L476RG/069d20c1-63b6-4979-b44a-2a426e5fe9f3/tool-results/bf7v9fd8n.txt'))\nprint(list(d.keys()))\nfor k,v in d.items():\n    if k in ('registers','callstack','threads','disasm_around_pc'): continue\n    print(k, '=', json.dumps(v)[:2000])\n\"",
