        "command": "d=$(pwd); while [ \"$d\" != \"/\" ]; do [ -f \"$d/stm32-project.jsonc\" ] && { echo \"FOUND: $d/stm32-project.jsonc\"; cat \"$d/stm32-project.jsonc\"; break; }; d=$(dirname \"$d\"); done; [ \"$d\" = \"/\" ] && echo \"no descriptor found\"",
        "description": "Locate and show stm32-project.jsonc descriptor"
