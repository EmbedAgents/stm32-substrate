      "name": "Bash",
      "args": {
        "command": "python3 -c \"\nimport json\nwith open('/home/user/.claude/projects/-home-user-claude-projects-stm32-substrate-tests-fixtures-projects-STM32CubeL4-Projects-NUCLEO-L476RG-Examples-GPIO-GPIO-IOToggle-STM32CubeIDE/8ffa6ce1-a4ca-4267-b8e7-aa16e5889cfc/tool-results/bd7f5ge5b.txt') as f:\n    d = json.load(f)\ncsr = d['registers'].get('CSR', {})\nprint('CSR raw:', hex(csr.get('raw_value', 0)))\nfor name, field in csr.get('fields', {}).items():\n    if field['raw_value']:\n        print(f'  {name} = {field[\\\"raw_value\\\"]} ({field.get(\\\"enum_name\\\",\\\"\\\")})')\n\"\n",
        "description": "Extract RCC_CSR reset-cause flags from saved dump"
