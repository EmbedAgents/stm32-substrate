    {
      "name": "Bash",
      "args": {
        "command": "python3 -c \"\nimport json\nd=json.load(open('/home/anup/.claude/projects/-home-anup-claude-projects-stm32-substrate-tests-fixtures-projects-F-PROJ-NUCLEO-L476RG/1ab7c437-713d-4ab6-97ed-e4aec6bb8061/tool-results/brwdh9njk.txt'))\nregs=d['peripheral_dumps'][0]['registers']\nfor name in ('CFSR_UFSR_BFSR_MMFSR','CFSR','HFSR','MMFAR','BFAR','AFSR','SHCSR'):\n    r=regs.get(name)\n    if not r: continue\n    print(name, hex(r['raw_value']))\n    for f,fd in r.get('fields',{}).items():\n        if fd['raw_value']: print('  ',f,'=',fd['raw_value'])\n\"",
        "description": "Print CFSR/HFSR/BFAR set bits"
