// stm32-project.jsonc — NUCLEO-G070RB board-recipe-suite descriptor (in-repo).
//
// Run:  STM32_BOARD_PROJECT=tests/fixtures/board-projects/nucleo-g070rb \
//         pytest -m hardware tests/test_board_recipe_suite.py -v
//
// The CubeIDE project tree itself is user-provided and lives OUTSIDE the
// repo (an ST CubeG0 examples checkout), so the build/elf/workspace paths
// below are ABSOLUTE and bench-local — adjust them to your checkout. The
// descriptor is committed (the n6 pattern: descriptor in-repo, tree not).
// Because this descriptor sits in-repo, the six vendor CLIs resolve via
// the repo's .claude/stm32-tools.local.jsonc (no per-tool env vars needed).
//
// Cortex-M0+ (STM32G0). HW-validated 27/1-skip (DBGMCU absent from SVD).
{
  "$schema": "../../../../src/embedagents/stm32/schemas/stm32-project.schema.json",
  "version": 1,
  "project_name": "FreeRTOS_Mail",
  "board": {
    "name": "NUCLEO-G070RB",
    "mcu": "STM32G070RBTx",
    "interface": "swd"
  },
  "firmware": {
    "flash_address": "0x08000000",
    "device_family": "STM32G0",
    "board": "NUCLEO-G070RB"
  },
  "build": {
    "workspace": "/mnt/data/github-cubemx/.board-workspaces/nucleo-g070rb",
    "project_path": "/mnt/data/github-cubemx/STM32CubeG0/Projects/NUCLEO-G070RB/Applications/FreeRTOS/FreeRTOS_Mail/STM32CubeIDE",
    "project_name": "FreeRTOS_Mail",
    "default_configuration": "Debug",
    "configurations": ["Debug", "Release"],
    "artifact": "Debug/FreeRTOS_Mail.elf"
  },
  "debug": {
    "elf_path": "/mnt/data/github-cubemx/STM32CubeG0/Projects/NUCLEO-G070RB/Applications/FreeRTOS/FreeRTOS_Mail/STM32CubeIDE/Debug/FreeRTOS_Mail.elf"
  }
}
