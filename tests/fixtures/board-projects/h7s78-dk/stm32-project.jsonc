// stm32-project.jsonc — STM32H7S78-DK board-recipe-suite descriptor (in-repo).
//
// Run:  STM32_BOARD_PROJECT=tests/fixtures/board-projects/h7s78-dk \
//         pytest -m hardware tests/test_board_recipe_suite.py -v
//
// The H7S78-DK MSC_Standalone is a DUAL-project design: Boot runs from
// internal flash (0x08000000), Appli runs from external XSPI ROM
// (0x70000000, needs an external loader — F-010/F-015 territory). This
// descriptor targets the BOOT subproject — the clean internal-flash path
// that exercises the full recipe surface (build / flash / debug-reads)
// without the external-loader dependency. (Appli-via-external-loader is a
// follow-up.) The CubeH7RS tree is in-repo (gitignored), so project_path
// is repo-relative + portable; tools resolve via the repo .claude/ config.
//
// Cortex-M7 (STM32H7RS). board.mcu STM32H7S7L8Hx → STM32H7S.svd (the H7RS
// family SVD). The connect banner is the family wildcard STM32H7RSxx, so
// svd_for_attached resolves via the board.mcu fallback.
//
// STATUS (2026-05-25): CubeProgrammer half GREEN on bench (12 checks:
// connect/cores/ping/board-name/memory/svd-for-attached/option-bytes/
// build/flash/reset/halt-resume/vcp). The 16 debug-read checks are
// BENCH-BLOCKED: ST-LINK_gdbserver v7.13.0 fails at device init with
// "Target unknown error 32" (the H7RS boots from external XSPI; the
// gdbserver can't init the target while CubeProgrammer can — not FW
// [V3J17M10], not a wedged probe [power-cycled], not reset-mode [-g/-k
// both fail]). HW-blocked, deferred — see [[project_h7s78_dk_gdbserver_blocked]].
{
  "$schema": "../../../../src/stm32_substrate/schemas/stm32-project.schema.json",
  "version": 1,
  "project_name": "MSC_Standalone_Boot",
  "board": {
    "name": "STM32H7S78-DK",
    "mcu": "STM32H7S7L8Hx",
    "interface": "swd"
  },
  "firmware": {
    "flash_address": "0x08000000",
    "device_family": "STM32H7RS",
    "board": "STM32H7S78-DK"
  },
  "build": {
    "workspace": "/mnt/data/github-cubemx/.board-workspaces/h7s78-dk",
    "project_path": "../../projects/STM32CubeH7RS/Projects/STM32H7S78-DK/Applications/USB_Device/MSC_Standalone/STM32CubeIDE/Boot",
    "project_name": "MSC_Standalone_Boot",
    "default_configuration": "Debug",
    "configurations": ["Debug", "Release"],
    "artifact": "Debug/MSC_Standalone_Boot.elf"
  },
  "debug": {
    "elf_path": "../../projects/STM32CubeH7RS/Projects/STM32H7S78-DK/Applications/USB_Device/MSC_Standalone/STM32CubeIDE/Boot/Debug/MSC_Standalone_Boot.elf"
  }
}
