// stm32-project.jsonc — NUCLEO-L552ZE-Q board-recipe-suite descriptor (in-repo).
//
// Run:  STM32_BOARD_PROJECT=tests/fixtures/board-projects/nucleo-l552ze-q \
//         pytest -m hardware tests/test_board_recipe_suite.py -v
//
// CubeIDE project tree is user-provided + OUTSIDE the repo (ST CubeL5
// examples checkout); the paths below are ABSOLUTE + bench-local. See the
// nucleo-g070rb descriptor for the rationale.
//
// Cortex-M33 (STM32L5, TrustZone-capable; FreeRTOS_MPU is a single image at
// 0x08000000). board.mcu STM32L552ZETxQ → STM32L552.svd.
{
  "$schema": "../../../../src/stm32_substrate/schemas/stm32-project.schema.json",
  "version": 1,
  "project_name": "FreeRTOS_MPU",
  "board": {
    "name": "NUCLEO-L552ZE-Q",
    "mcu": "STM32L552ZETxQ",
    "interface": "swd"
  },
  "firmware": {
    "flash_address": "0x08000000",
    "device_family": "STM32L5",
    "board": "NUCLEO-L552ZE-Q"
  },
  "build": {
    "workspace": "/mnt/data/github-cubemx/.board-workspaces/nucleo-l552ze-q",
    "project_path": "/mnt/data/github-cubemx/STM32CubeL5/Projects/NUCLEO-L552ZE-Q/Applications/FreeRTOS/FreeRTOS_MPU/STM32CubeIDE",
    "project_name": "FreeRTOS_MPU",
    "default_configuration": "Debug",
    "configurations": ["Debug", "Release"],
    "artifact": "Debug/FreeRTOS_MPU.elf"
  },
  "debug": {
    "elf_path": "/mnt/data/github-cubemx/STM32CubeL5/Projects/NUCLEO-L552ZE-Q/Applications/FreeRTOS/FreeRTOS_MPU/STM32CubeIDE/Debug/FreeRTOS_MPU.elf"
  }
}
