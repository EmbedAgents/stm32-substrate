// stm32-project.jsonc — NUCLEO-U083RC board-recipe-suite descriptor (in-repo).
//
// Run:  STM32_BOARD_PROJECT=tests/fixtures/board-projects/nucleo-u083rc \
//         pytest -m hardware tests/test_board_recipe_suite.py -v
//
// CubeIDE project tree is user-provided + OUTSIDE the repo (ST CubeU0
// examples checkout); the paths below are ABSOLUTE + bench-local. See the
// nucleo-g070rb descriptor for the rationale (tree gitignored, descriptor
// committed; CLIs resolve via the repo's .claude/ tools config).
//
// Cortex-M0+ (STM32U0). HW-validated 28/0. svd_for_attached resolves via
// the board.mcu fallback (U0 banner is the family-only wildcard STM32U0xx).
{
  "$schema": "../../../../src/embedagents/stm32/schemas/stm32-project.schema.json",
  "version": 1,
  "project_name": "Tx_Thread_Creation",
  "board": {
    "name": "NUCLEO-U083RC",
    "mcu": "STM32U083RCTx",
    "interface": "swd"
  },
  "firmware": {
    "flash_address": "0x08000000",
    "device_family": "STM32U0",
    "board": "NUCLEO-U083RC"
  },
  "build": {
    "workspace": "/mnt/data/github-cubemx/.board-workspaces/nucleo-u083rc",
    "project_path": "/mnt/data/github-cubemx/STM32CubeU0/Projects/NUCLEO-U083RC/Applications/ThreadX/Tx_Thread_Creation/STM32CubeIDE",
    "project_name": "Tx_Thread_Creation",
    "default_configuration": "Debug",
    "configurations": ["Debug", "Release"],
    "artifact": "Debug/Tx_Thread_Creation.elf"
  },
  "debug": {
    "elf_path": "/mnt/data/github-cubemx/STM32CubeU0/Projects/NUCLEO-U083RC/Applications/ThreadX/Tx_Thread_Creation/STM32CubeIDE/Debug/Tx_Thread_Creation.elf"
  }
}
